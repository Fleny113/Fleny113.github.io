---
import { Icon } from "astro-icon/components";
import { assert } from "#/utils.ts";

assert(Astro.slots.has("summary"), "Project component requires a 'summary' slot");
assert(Astro.slots.has("details"), "Project component requires a 'details' slot");

interface Props {
    children: unknown;
    expanded?: boolean;
}
---

<details open={Astro.props.expanded}>
    <summary>
        <Icon size={30} name="mdi:chevron-right" class="icon" aria-hidden />
        <div>
            <slot name="summary" />
        </div>
    </summary>

    <slot name="details" />
</details>

<style>
    details {
        display: flex;
        flex-direction: column;

        interpolate-size: allow-keywords;

        &:not(:last-child) {
            border-bottom: 3px var(--border);
        }
    }

    summary {
        text-align: left;

        display: grid;
        grid-template-columns: auto 1fr auto;

        padding: 0.5rem;
        border-bottom: 0px var(--border);
        cursor: pointer;

        transition:
            border-bottom 0.3s ease,
            background-color 0.3s ease;

        &:hover {
            background-color: hsl(0 0 100 / 0.1);
        }

        details[open] & {
            border-bottom: 3px var(--border);
        }

        .icon {
            place-self: center;
            width: 1.5rem;
            aspect-ratio: 1;

            transform-origin: center;

            details[open] & {
                rotate: 90deg;
            }
        }
    }

    details::details-content {
        overflow: hidden;
        height: 0;

        /* content-visibility is required to animate when the details is being closed */
        transition:
            height 0.3s ease,
            padding-top 0.3s ease,
            content-visibility 0.3s allow-discrete;
    }

    details[open]::details-content {
        height: auto;
        padding-block: 0.5rem;
    }
</style>
